# Core database configuration
DATABASE_URL=postgres://walletguard:walletguard@localhost:5432/walletguard?sslmode=disable

# Scanner inputs (comma-separated absolute paths)
SCAN_ROOTS=D:\walletguard\fixtures\demo-scan
GIT_REPO_PATHS=
S3_LOCAL_PATH=

# Scanner performance
WORKER_CONCURRENCY=8
CHUNK_SIZE_BYTES=1048576

# Optional enrichment RPC endpoints
EVM_RPC_URL=https://ethereum.publicnode.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional notifications
SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=

# API server
LISTEN=:8080

# Worker (cmd/worker)
WORKER_POLL_INTERVAL=5m
